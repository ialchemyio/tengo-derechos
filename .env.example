# =============================================================
# Tengo Derechos — environment variables
# Copy to .env.local for development.
# =============================================================

# --- Site ---
# Used by API routes to build absolute success/cancel URLs.
NEXT_PUBLIC_SITE_URL=https://tengoderechos.org

# Bake a deterministic cache version into the service worker.
# Set this to the git SHA in CI so each deploy invalidates older caches.
NEXT_PUBLIC_BUILD_ID=

# --- Stripe (donations) ---
# Without these, the donation UI degrades gracefully (503 message).
# Use test keys (sk_test_* / pk_test_*) in development.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: a precreated $25/month Price ID. When set and a donor
# selects monthly + $25, Checkout uses this Price instead of creating
# a recurring price on the fly. Useful for analytics / reporting.
STRIPE_PRICE_MONTHLY_25=

# --- Nonprofit status ---
# pending | confirmed | denied
# Drives the on-page banner and tax-deductibility copy.
NEXT_PUBLIC_NONPROFIT_STATUS=pending

# Display only when status is confirmed.
NEXT_PUBLIC_NONPROFIT_EIN=

# --- Donations log (server) ---
# Append-only JSONL of webhook events. Use a writable absolute path
# in production; default is data/donations.jsonl relative to cwd.
DONATIONS_LOG_PATH=data/donations.jsonl
